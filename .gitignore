# ─── NEVER COMMIT CAPTURED SLACK DATA OR THE BINARY ───
# Your exported messages, DMs and attachments live here. Keep them local.
/data/

# slackdump binary is fetched per-machine by setup; don't ship it.
/bin/

# Python virtual environment + caches
/.venv/
venv/
__pycache__/
*.pyc
*.pyo

# slackdump stray outputs (in case anyone runs it from the repo root)
channels-*.txt
users-*.txt
slackdump_*.zip
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Search index (rebuildable from data/)
search.db

# Your personal channel selection (generated by `pick-channels`; contains your
# channel names). The committed template is channels.example.txt.
/channels.txt
/channels.txt.bak

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
